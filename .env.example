# ─────────────────────────────────────────────────────────────────────────────
# Outlook / Microsoft 365 PO email intake (Microsoft Graph API)
# Copy this file to ".env" and fill in the three values, then restart the app.
# The app loads these as environment variables.
# ─────────────────────────────────────────────────────────────────────────────

# Application (client) ID of an Entra (Azure AD) app registration.
# The app must be a PUBLIC CLIENT (mobile & desktop; "Allow public client flows" = Yes)
# with the delegated API permission "Microsoft Graph > Mail.Read" granted + consented.
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Directory (tenant) ID of your organisation (EY tenant).
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000

# Subject keyword used to identify PO emails in your Inbox (case-insensitive).
PO_SUBJECT_KEYWORD=purchase order
